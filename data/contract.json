{
  "catalog_models": [
    "z-image"
  ],
  "actions": {
    "z-image/text-to-image": {
      "model": "Z Image",
      "endpoint": "text_to_image",
      "models": [
        "z-image"
      ],
      "fields_by_model": {
        "z-image": {
          "prompt": {
            "max": 1000,
            "min": 1,
            "length": true,
            "required": true
          },
          "aspect_ratio": {
            "enum": [
              "1:1",
              "4:3",
              "3:4",
              "16:9",
              "9:16"
            ],
            "required": true
          }
        }
      }
    }
  }
}
